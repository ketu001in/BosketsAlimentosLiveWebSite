# Bosket's Alimentos — Apache/LiteSpeed configuration (Hostinger-compatible)

Options -Indexes

# ---- protect sensitive files
<FilesMatch "^(config\.php)$">
  Require all denied
</FilesMatch>

# ---- block hidden files & folders (.claude, .git, …) except .well-known
RedirectMatch 404 "/\.(?!well-known)"

# ---- friendly errors
ErrorDocument 404 /index.php

# ---- upload limits (Hostinger LiteSpeed honours these; otherwise set in hPanel -> PHP Configuration)
php_value upload_max_filesize 30M
php_value post_max_size 64M
php_value max_execution_time 120
php_value memory_limit 256M

# ---- gzip / deflate compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml font/woff2 font/woff font/ttf
  # Vary header so proxies/CDNs cache both compressed and uncompressed versions
  <IfModule mod_headers.c>
    Header append Vary Accept-Encoding
  </IfModule>
</IfModule>

# ---- browser caching (Expires)
<IfModule mod_expires.c>
  ExpiresActive On
  # Images
  ExpiresByType image/jpeg        "access plus 6 months"
  ExpiresByType image/png         "access plus 6 months"
  ExpiresByType image/webp        "access plus 6 months"
  ExpiresByType image/gif         "access plus 6 months"
  ExpiresByType image/svg+xml     "access plus 6 months"
  ExpiresByType image/x-icon      "access plus 1 year"
  # Video
  ExpiresByType video/mp4         "access plus 6 months"
  ExpiresByType video/webm        "access plus 6 months"
  # Fonts
  ExpiresByType font/woff2        "access plus 1 year"
  ExpiresByType font/woff         "access plus 1 year"
  ExpiresByType font/ttf          "access plus 1 year"
  # CSS & JS (versioned via ?v= query strings, so long cache is safe)
  ExpiresByType text/css          "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  # HTML / PHP — no cache (dynamic)
  ExpiresByType text/html         "access plus 0 seconds"
</IfModule>

# ---- Cache-Control headers
<IfModule mod_headers.c>
  # Static assets — long cache
  <FilesMatch "\.(ico|jpg|jpeg|png|gif|webp|svg|mp4|webm|woff|woff2|ttf)$">
    Header set Cache-Control "public, max-age=15552000, immutable"
  </FilesMatch>
  # CSS/JS — long cache (safe because we version with ?v=)
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # PHP pages — no cache
  <FilesMatch "\.php$">
    Header set Cache-Control "no-store, no-cache, must-revalidate"
    Header set Pragma "no-cache"
  </FilesMatch>

  # Security headers
  Header set X-Content-Type-Options  "nosniff"
  Header set X-Frame-Options         "SAMEORIGIN"
  Header set Referrer-Policy         "strict-origin-when-cross-origin"
  Header set Permissions-Policy      "geolocation=(), microphone=(), camera=()"
  Header set X-XSS-Protection        "1; mode=block"

  # Keep connections alive
  Header set Connection "keep-alive"
</IfModule>

# ---- disable ETags (reduces header size; Expires + Cache-Control are enough)
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>
FileETag None
