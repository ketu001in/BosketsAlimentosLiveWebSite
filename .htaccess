# Bosket's Alimentos — Apache/LiteSpeed configuration (Hostinger-compatible)

Options -Indexes

# ---- protect sensitive files
<FilesMatch "^(config\.php)$">
  Require all denied
</FilesMatch>

# ---- block hidden files & folders (.claude, .git, …) except .well-known
RedirectMatch 404 "/\.(?!well-known)"

# ---- friendly errors
ErrorDocument 404 /index.php

# ---- upload limits (Hostinger LiteSpeed honours these; otherwise set in hPanel -> PHP Configuration)
php_value upload_max_filesize 30M
php_value post_max_size 64M
php_value max_execution_time 120
php_value memory_limit 256M

# ---- basic hardening
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ---- cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType video/mp4 "access plus 30 days"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
</IfModule>
